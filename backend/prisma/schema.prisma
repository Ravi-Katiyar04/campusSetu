generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String
  role            Role     @default(STUDENT)
  profile         Profile?
  progress        Progress?
  moduleProgress  ModuleProgress[]
  createdAt       DateTime @default(now())
}

model Profile {
  id      String   @id @default(uuid())
  course String?
  college String?
  year    Int?     // ✅ make nullable
  skills  String[]
  userId  String   @unique
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Progress {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])

  level        Int      @default(1)
  xp           Int      @default(0)
  streak       Int      @default(0)
  lastActiveAt DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model Company {
  id            String   @id @default(uuid())
  name          String
  role          String
  packageOffered    Float
  questionsAsked String[]
  studentsPlaced Int
  year          Int
  eligibility   String?
  description   String?
  experience    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model StudentRegistry {
  id         Int     @id @default(autoincrement())
  rollNumber String  @unique
  email      String  @unique
  name       String
}

model Level {
  id          String   @id @default(uuid())
  name        String
  order       Int
  description String

  modules     Module[]
}

model Module {
  id        String   @id @default(uuid())
  title     String
  content   String
  levelId   String
  level     Level    @relation(fields: [levelId], references: [id])

  tasks     Task[]
  moduleProgress ModuleProgress[]
}

model Task {
  id        String   @id @default(uuid())
  title     String
  type      String
  link      String?
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id])
}

model ModuleProgress {
  id        String   @id @default(uuid())
  userId    String
  moduleId  String
  completed Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id])
  module    Module   @relation(fields: [moduleId], references: [id])

  @@unique([userId, moduleId])
}